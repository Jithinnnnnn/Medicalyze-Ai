# Azure Web App Environment Variables
# Copy these to Azure Portal > Configuration > Application settings

# Node.js Configuration
WEBSITE_NODE_DEFAULT_VERSION=22-lts
NODE_ENV=production

# Next.js Configuration
PORT=8080
NEXTAUTH_URL=https://medicalizer.azurewebsites.net
NEXTAUTH_SECRET=generate-a-random-secret-here-use-openssl-rand-base64-32

# OpenAI API (if using AI features)
OPENAI_API_KEY=your-openai-api-key-here

# Google OAuth (if using authentication)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Optional: Application Insights (for monitoring)
# APPLICATIONINSIGHTS_CONNECTION_STRING=your-connection-string-here
